(deflisten workspaces "~/.config/i3/hanauta/src/eww/scripts/workspaces")
;(deflisten windowtitle "~/.config/i3/hanauta/src/eww/scripts/windowtitle")
(deflisten tray "tail -F ~/.config/i3/hanauta/scripts/tray-status 2> /dev/null")
