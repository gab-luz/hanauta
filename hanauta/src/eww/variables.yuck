;(defpoll music_status :interval "1s" "~/.config/i3/hanauta/src/eww/scripts/music/songdata.sh status")

(defpoll completeday :interval "30m" "date '+%A, %d %B'")
(defpoll lithour :interval "30s" "date +%H")
(defpoll litmin :interval "30s" "date +%M")
(defpoll timeku :interval "15s" "date '+%H:%M %p'")
(defpoll calendar_day :interval "11h" "date '+%d'")
(defpoll calendar_month :interval "11h" "date '+%m'")
(defpoll calendar_year :interval "11h" "date '+%Y'")
(defpoll date :interval "30s" "date '+ %a %d %b, %I:%M %p'")
(defpoll shortday :interval "1h" "date '+%d %b %y'")
(defpoll weekday :interval "24h" "date +%A")

(defpoll cpu :interval "5s" "~/.config/i3/hanauta/src/eww/scripts/cpu.sh")
(defpoll ram :interval "5s" "~/.config/i3/hanauta/src/eww/scripts/ram.sh ram")
(defpoll temp :interval "5s" :initial "0" "/bin/sh -c 'v=$(~/.config/i3/hanauta/src/eww/scripts/temp.sh get 2>/dev/null); [ -n \"$v\" ] || v=0; printf \"%s\\n\" \"$v\"'")
(defpoll disk :interval "30s" "~/.config/i3/hanauta/src/eww/scripts/disk.sh")

(defpoll art		:interval "5s"  "~/.config/i3/hanauta/src/eww/scripts/mpris.sh coverloc")
(defpoll title		:interval "5s"  "~/.config/i3/hanauta/src/eww/scripts/mpris.sh title")
