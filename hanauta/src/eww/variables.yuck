(defpoll network_status :interval "8s" "~/.config/i3/hanauta/src/eww/scripts/network.sh status")
(defpoll network_icon :interval "8s" "~/.config/i3/hanauta/src/eww/scripts/network.sh icon")
(defpoll network_radio :interval "8s" "~/.config/i3/hanauta/src/eww/scripts/network.sh radio-status")
(defpoll network_ssid :interval "8s" "~/.config/i3/hanauta/src/eww/scripts/network.sh ssid")

(defpoll volume_icon :interval "5s" "~/.config/i3/hanauta/src/eww/scripts/volume.sh icon")
(defpoll volume :interval "5s" "~/.config/i3/hanauta/src/eww/scripts/volume.sh percentage")
(defpoll volume_value :interval "5s" :initial "0" "/bin/sh -c 'v=$(~/.config/i3/hanauta/src/eww/scripts/volume.sh vol 2>/dev/null); [ -n \"$v\" ] || v=0; printf \"%s\\n\" \"$v\"'")
(defpoll is_muted :interval "5s" "~/.config/i3/hanauta/src/eww/scripts/volume.sh muted")
(defpoll phone_name :interval "15s" "~/.config/i3/hanauta/src/eww/scripts/phone_info.sh name")
(defpoll phone_battery :interval "15s" "~/.config/i3/hanauta/src/eww/scripts/phone_info.sh battery")
(defpoll phone_status :interval "15s" "~/.config/i3/hanauta/src/eww/scripts/phone_info.sh status")
(defpoll phone_data
  :interval "15s"
  :initial "{\"id\":\"\",\"name\":\"No device\",\"battery\":\"0\",\"status\":\"Disconnected\",\"clipboard\":\"off\"}"
  "/bin/sh -c 'v=$(~/.config/i3/hanauta/src/eww/scripts/phone_info.sh 2>/dev/null); [ -n \"$v\" ] || v=\"{\\\"id\\\":\\\"\\\",\\\"name\\\":\\\"No device\\\",\\\"battery\\\":\\\"0\\\",\\\"status\\\":\\\"Disconnected\\\",\\\"clipboard\\\":\\\"off\\\"}\"; printf \"%s\\n\" \"$v\"'")
(defpoll mic :interval "8s" "~/.config/i3/hanauta/src/eww/scripts/mic get")
(defpoll mic_status :interval "8s" "~/.config/i3/hanauta/src/eww/scripts/mic status")

(defpoll bluetooth_state :interval "8s" "~/.config/i3/hanauta/src/eww/scripts/bluetooth state")
(defpoll redshift_state :interval "15s" "~/.config/i3/hanauta/src/eww/scripts/redshift state")

(defpoll pfp :interval "30s" "~/.config/i3/hanauta/src/eww/scripts/pfp.sh")
(defpoll rawuser :interval "30s" "whoami")
(defpoll username :interval "30s" "~/.config/i3/hanauta/src/eww/scripts/user.sh")
(defpoll hostname :interval "30s" "cat /etc/hostname")
(defpoll uptime :interval "30s" "uptime -p")

(defpoll br_icon :interval "5s" "~/.config/i3/hanauta/src/eww/scripts/brightness.sh icon")
(defpoll br :interval "5s" :initial "0" "/bin/sh -c 'v=$(~/.config/i3/hanauta/src/eww/scripts/brightness.sh br 2>/dev/null); [ -n \"$v\" ] || v=0; printf \"%s\\n\" \"$v\"'")

(defpoll vpn_wireguard :interval "5s" "~/.config/i3/hanauta/src/eww/scripts/vpn.sh --status | grep -o '\"wireguard\": \"[^\"]*\"' | cut -d'\"' -f4")
(defpoll vpn_tailscale :interval "5s" "~/.config/i3/hanauta/src/eww/scripts/vpn.sh --status | grep -o '\"tailscale\": \"[^\"]*\"' | cut -d'\"' -f4")
(defpoll vpn_wg_selected :interval "5s" "~/.config/i3/hanauta/src/eww/scripts/vpn.sh --status | grep -o '\"wg_selected\": \"[^\"]*\"' | cut -d'\"' -f4")

;(defpoll music_pic :interval "2s" "~/.config/i3/hanauta/src/eww/scripts/music/songart.sh get")
;(defpoll music_url :interval "2s" "~/.config/i3/hanauta/src/eww/scripts/music/songart.sh echo")

