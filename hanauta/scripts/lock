#!/bin/bash
set -Eeuo pipefail

fg=c0caf5
wrong=db4b4b
highlight=565f89
date=7aa2f7
verify=9ece6a
layout=bb9af7
dim_text=a9b1d6

slowfade () {
    dis=$(echo -n "$DISPLAY" | tr -c '[:alnum:]' _)
    ifc='com.github.chjj.compton'
    obj='/com/github/chjj/compton'
    if [[ "$1" == "start" ]]; then
        dbus-send --dest=$ifc.$dis \
            $obj $ifc.opts_set string:fade_in_step double:0.02
        dbus-send --dest=$ifc.$dis \
            $obj $ifc.opts_set string:fade_out_step double:0.02
    else
        dbus-send --dest=$ifc.$dis \
            $obj $ifc.opts_set string:fade_in_step double:0.1
        dbus-send --dest=$ifc.$dis \
            $obj $ifc.opts_set string:fade_out_step double:0.1
    fi
}

pkill -u "$USER" -USR1 dunst || true
slowfade start
if command -v mpc >/dev/null 2>&1 && mpc status >/dev/null 2>&1; then
    mpc pause >/dev/null 2>&1
fi

tmp_raw=""
tmp_lock=""
cleanup() {
    [[ -n "$tmp_raw" && -f "$tmp_raw" ]] && rm -f "$tmp_raw"
    [[ -n "$tmp_lock" && -f "$tmp_lock" ]] && rm -f "$tmp_lock"
}
trap cleanup EXIT

wallpaper="$HOME/.wallpapers/wallpaper.png"
if [[ ! -f "$wallpaper" ]]; then
    wallpaper=""
fi

local_i3lock_color="$HOME/.config/i3/bin/i3lock-color"

if [[ -z "$wallpaper" ]]; then
    for candidate in \
        "$HOME/.config/i3/hanauta/walls/ryan-3.png" \
        "$HOME/.config/i3/hanauta/walls/ryan-4.png" \
        "$HOME/.config/i3/hanauta/walls/ryan-6.png" \
        "$HOME/.config/i3/hanauta/walls/ryan-7.png" \
        "$HOME/.config/i3/hanauta/walls/ryan-8.png" \
        "$HOME/.config/i3/hanauta/walls/"*.png \
        "$HOME/.config/i3/hanauta/walls/"*.jpg \
        "$HOME/.config/i3/hanauta/walls/"*.jpeg
    do
        if [[ -f "$candidate" ]]; then
            wallpaper="$candidate"
            break
        fi
    done
fi

lock_image="$wallpaper"
if command -v maim >/dev/null 2>&1 && command -v magick >/dev/null 2>&1; then
    tmp_raw="$(mktemp --suffix=.png)"
    tmp_lock="$(mktemp --suffix=.png)"
    if maim "$tmp_raw" >/dev/null 2>&1; then
        if magick "$tmp_raw" -blur 0x8 "$tmp_lock" >/dev/null 2>&1; then
            lock_image="$tmp_lock"
        fi
    fi
fi

ind_pos="x+w/2:y+h/2+42"
time_pos="x+w/2:y+h/2-150"
date_pos="x+w/2:y+h/2-100"
greeter_pos="x+w/2:y+h/2-56"
layout_pos="x+w/2:y+h/2-24"
status_pos="x+w/2:y+h/2+120"

locker="$HOME/.config/i3/bin/i3lock"
if ! "$locker" --help >/dev/null 2>&1; then
    locker="$(command -v i3lock)"
fi

# Prefer local i3lock-color only if it is actually runnable on this system.
if [[ -x "$local_i3lock_color" ]] && "$local_i3lock_color" -v >/dev/null 2>&1; then
    "$local_i3lock_color" -n --force-clock -i "$lock_image" -e \
        --indicator \
        --radius=28 \
        --ring-width=6 \
        --line-uses-inside \
        --inside-color=00000000 \
        --ring-color=${fg}dd \
        --separator-color=00000000 \
        --insidever-color=00000000 \
        --ringver-color=${verify}ff \
        --insidewrong-color=00000000 \
        --ringwrong-color=${wrong}ff \
        --keyhl-color=${verify}ff \
        --bshl-color=${wrong}ff \
        --time-str="%H:%M" \
        --time-size=88 \
        --time-font="Roboto:style=Bold" \
        --time-color=${fg}ff \
        --time-align=1 \
        --time-pos="${time_pos}" \
        --date-str="%A, %d %B %Y" \
        --date-size=24 \
        --date-font="Roboto" \
        --date-color=${date}ff \
        --date-align=1 \
        --date-pos="${date_pos}" \
        --greeter-text="Hanauta locked • Type your password to unlock" \
        --greeter-size=18 \
        --greeter-font="Roboto" \
        --greeter-color=${dim_text}ff \
        --greeter-align=1 \
        --greeter-pos="${greeter_pos}" \
        --layout-color=${layout}ff \
        --layout-size=16 \
        --layout-font="Roboto" \
        --layout-align=1 \
        --layout-pos="${layout_pos}" \
        --verif-text="Verifying..." \
        --verif-size=16 \
        --verif-font="Roboto" \
        --verif-color=${verify}ff \
        --verif-align=1 \
        --verif-pos="${status_pos}" \
        --wrong-text="Wrong password" \
        --wrong-size=16 \
        --wrong-font="Roboto" \
        --wrong-color=${wrong}ff \
        --wrong-align=1 \
        --wrong-pos="${status_pos}" \
        --noinput-text="" \
        --ind-pos="${ind_pos}" \
        --pointer=default \
        --refresh-rate=1 \
        --pass-media-keys \
        --pass-volume-keys
elif [[ "$locker" == "$HOME/.config/i3/bin/i3lock" ]]; then
    "$locker" -n --force-clock -i "$lock_image" -e --indicator --radius=20 --ring-width=40 --inside-color=$fg --ring-color=$fg --insidever-color=$verify --ringver-color=$verify --insidewrong-color=$wrong --ringwrong-color=$wrong --line-uses-inside --keyhl-color=$verify --separator-color=$verify --bshl-color=$verify --time-str="%H:%M" --time-size=100 --date-str="%a, %d %b" --date-size=40 --verif-text="Verifying Password..." --wrong-text="Wrong Password!" --noinput-text="" --greeter-text="Type the password to Unlock" --ind-pos="160:600" --time-font="Roboto:style=Bold" --date-font="Roboto" --verif-font="Roboto" --greeter-font="Roboto" --wrong-font="Roboto" --verif-size=16 --greeter-size=16 --wrong-size=16 --time-pos="160:190" --date-pos="160:250" --greeter-pos="160:400" --wrong-pos="160:500" --verif-pos="160:450" --date-color=$date --time-color=$date --greeter-color=$fg --wrong-color=$wrong --verif-color=$verify --verif-pos="160:470" --pointer=default --refresh-rate=0 --pass-media-keys --pass-volume-keys
else
    "$locker" -n -e -i "$lock_image" -p default
fi
slowfade end 
