#!/bin/bash
set -Eeuo pipefail

fg=c0caf5
wrong=db4b4b
highlight=565f89
date=7aa2f7
verify=9ece6a
layout=bb9af7
dim_text=a9b1d6
settings_file="${HANAUTA_SETTINGS_FILE:-$HOME/.local/state/hanauta/notification-center/settings.json}"
lock_blur=0
pause_media_on_lock=1
use_slow_fade=1
prefer_i3lock_color=1
show_clock=1
show_indicator=1
pass_media_keys=1
pass_volume_keys=1
refresh_rate=1
ring_radius=28
ring_width=6
time_format="%H:%M"
date_format="%A, %d %B %Y"
greeter_text="Hanauta locked • Type your password to unlock"
verifying_text="Verifying..."
wrong_text="Wrong password"
theme_root="${HOME}/.config/betterlockscreen"
theme_dir="${theme_root}/themes"
active_theme_file="${theme_root}/betterlockscreenrc"
active_theme_marker="${HOME}/.cache/betterlockscreen/.betterlock-theme.txt"
theme_name="hanauta-anime"
theme_font="Rubik"
theme_time_color="e0e3e8ff"
theme_greeter_color="a9b1d6ff"
theme_layout_color="bb9af7ff"
theme_weather_color="8ce9b0ff"
theme_panel_fill="#101417aa"
overlay_width=860
overlay_height=300
overlay_bottom_margin=84

run_quick() {
    # Keep pre-lock probes from stalling the lock path (notably mpc when MPD is down).
    if command -v timeout >/dev/null 2>&1; then
        timeout 0.35s "$@"
    else
        "$@"
    fi
}

load_lock_settings() {
    [[ -f "$settings_file" ]] || return 0
    command -v python3 >/dev/null 2>&1 || return 0
    while IFS='=' read -r key value; do
        case "$key" in
            blur_screenshot) lock_blur="$value" ;;
            pause_media_on_lock) pause_media_on_lock="$value" ;;
            use_slow_fade) use_slow_fade="$value" ;;
            prefer_i3lock_color) prefer_i3lock_color="$value" ;;
            show_clock) show_clock="$value" ;;
            show_indicator) show_indicator="$value" ;;
            pass_media_keys) pass_media_keys="$value" ;;
            pass_volume_keys) pass_volume_keys="$value" ;;
            refresh_rate) refresh_rate="$value" ;;
            ring_radius) ring_radius="$value" ;;
            ring_width) ring_width="$value" ;;
            time_format) time_format="$value" ;;
            date_format) date_format="$value" ;;
            greeter_text) greeter_text="$value" ;;
            verifying_text) verifying_text="$value" ;;
            wrong_text) wrong_text="$value" ;;
        esac
    done < <(
        python3 - "$settings_file" <<'PY'
import json
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    payload = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    payload = {}
lock = payload.get("lockscreen", {})
defaults = {
    "blur_screenshot": False,
    "pause_media_on_lock": True,
    "use_slow_fade": True,
    "prefer_i3lock_color": True,
    "show_clock": True,
    "show_indicator": True,
    "pass_media_keys": True,
    "pass_volume_keys": True,
    "refresh_rate": 1,
    "ring_radius": 28,
    "ring_width": 6,
    "time_format": "%H:%M",
    "date_format": "%A, %d %B %Y",
    "greeter_text": "Hanauta locked • Type your password to unlock",
    "verifying_text": "Verifying...",
    "wrong_text": "Wrong password",
}
for key, default in defaults.items():
    value = lock.get(key, default)
    if isinstance(default, bool):
        out = "1" if bool(value) else "0"
    elif isinstance(default, int):
        try:
            out = str(int(value))
        except Exception:
            out = str(default)
    else:
        out = str(value).replace("\n", " ")
    print(f"{key}={out}")
PY
    )
}

ensure_theme_creator_theme() {
    local theme_file="${theme_dir}/${theme_name}.theme"
    mkdir -p "$theme_dir" "$(dirname "$active_theme_marker")"
    cat > "$theme_file" <<'EOF'
loginshadow=00000000
loginbox=00000000
locktext="♪ hanauta"
ringcolor=97ccf9cc
font=Rubik
insidecolor=10141788
separatorcolor=00000000
ringvercolor=8ce9b0ff
insidevercolor=10141788
ringwrongcolor=ffb4abff
insidewrongcolor=10141788
timecolor=e0e3e8ff
time_format=%H:%M
greetercolor=a9b1d6ff
layoutcolor=bb9af7ff
keyhlcolor=8ce9b0ff
bshlcolor=ffb4abff
veriftext="Verifying..."
verifcolor=8ce9b0ff
wrongtext="Wrong password"
wrongcolor=ffb4abff
modifcolor=97ccf9ff
bgcolor=101417ff
EOF
    cp -f "$theme_file" "$active_theme_file"
    printf '%s\n' "$theme_file" > "$active_theme_marker"
}

load_active_theme() {
    local source_file="$active_theme_file"
    if [[ -f "$active_theme_marker" ]]; then
        local marked
        marked="$(cat "$active_theme_marker" 2>/dev/null || true)"
        if [[ -n "$marked" && -f "$marked" ]]; then
            source_file="$marked"
        fi
    fi
    [[ -f "$source_file" ]] || return 0

    # Theme files come from betterlockscreen-theme-creator and are shell-style assignments.
    # shellcheck disable=SC1090
    source "$source_file"

    [[ -n "${font:-}" ]] && theme_font="$font"
    [[ -n "${timecolor:-}" ]] && theme_time_color="$timecolor"
    [[ -n "${greetercolor:-}" ]] && theme_greeter_color="$greetercolor"
    [[ -n "${layoutcolor:-}" ]] && theme_layout_color="$layoutcolor"
}

get_primary_monitor_size() {
    command -v xrandr >/dev/null 2>&1 || {
        printf '%s\n' "1920 1080"
        return 0
    }
    python3 - <<'PY'
import re
import subprocess

try:
    out = subprocess.check_output(["xrandr", "--query"], text=True)
except Exception:
    print("1920 1080")
    raise SystemExit(0)

primary = re.search(r"^\S+\s+connected\s+primary\s+(\d+)x(\d+)\+\d+\+\d+", out, re.M)
if primary:
    print(primary.group(1), primary.group(2))
    raise SystemExit(0)

any_conn = re.search(r"^\S+\s+connected(?:\s+primary)?\s+(\d+)x(\d+)\+\d+\+\d+", out, re.M)
if any_conn:
    print(any_conn.group(1), any_conn.group(2))
else:
    print("1920 1080")
PY
}

slowfade () {
    dis=$(echo -n "$DISPLAY" | tr -c '[:alnum:]' _)
    ifc='com.github.chjj.compton'
    obj='/com/github/chjj/compton'
    if [[ "$1" == "start" ]]; then
        dbus-send --dest=$ifc.$dis \
            $obj $ifc.opts_set string:fade_in_step double:0.02
        dbus-send --dest=$ifc.$dis \
            $obj $ifc.opts_set string:fade_out_step double:0.02
    else
        dbus-send --dest=$ifc.$dis \
            $obj $ifc.opts_set string:fade_in_step double:0.1
        dbus-send --dest=$ifc.$dis \
            $obj $ifc.opts_set string:fade_out_step double:0.1
    fi
}

resolve_current_wallpaper() {
    local candidate=""
    local from_fehbg=""

    # Primary Hanauta path written by set_wallpaper.sh.
    candidate="$HOME/.wallpapers/wallpaper.png"
    if [[ -f "$candidate" ]]; then
        printf '%s\n' "$candidate"
        return 0
    fi

    # If it is a symlink and target still exists, use the resolved target.
    if [[ -L "$candidate" ]]; then
        candidate="$(readlink -f "$candidate" 2>/dev/null || true)"
        if [[ -n "$candidate" && -f "$candidate" ]]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    fi

    # Fallback to current feh state.
    if [[ -f "$HOME/.fehbg" ]]; then
        from_fehbg="$(
            python3 - "$HOME/.fehbg" <<'PY'
import shlex
import sys
from pathlib import Path

fehbg = Path(sys.argv[1])
line = ""
try:
    for raw in fehbg.read_text(encoding="utf-8").splitlines():
        raw = raw.strip()
        if raw and not raw.startswith("#"):
            line = raw
            break
except Exception:
    pass

if not line:
    print("")
    raise SystemExit(0)

try:
    parts = shlex.split(line)
except Exception:
    print("")
    raise SystemExit(0)

path = ""
for tok in reversed(parts):
    if tok.startswith("-"):
        continue
    path = tok
    break

print(path)
PY
        )"
        if [[ -n "$from_fehbg" && -f "$from_fehbg" ]]; then
            printf '%s\n' "$from_fehbg"
            return 0
        fi
    fi

    # Last resort: known bundled wallpaper candidates.
    for candidate in \
        "$HOME/.config/i3/hanauta/walls/ryan-3.png" \
        "$HOME/.config/i3/hanauta/walls/ryan-4.png" \
        "$HOME/.config/i3/hanauta/walls/ryan-6.png" \
        "$HOME/.config/i3/hanauta/walls/ryan-7.png" \
        "$HOME/.config/i3/hanauta/walls/ryan-8.png" \
        "$HOME/.config/i3/hanauta/walls/"*.png \
        "$HOME/.config/i3/hanauta/walls/"*.jpg \
        "$HOME/.config/i3/hanauta/walls/"*.jpeg
    do
        if [[ -f "$candidate" ]]; then
            printf '%s\n' "$candidate"
            return 0
        fi
    done

    printf '%s\n' ""
}

pick_random_anime_wallpaper() {
    local roots=(
        "$HOME/.local/share/hanauta/walls"
        "$HOME/.config/i3/hanauta/walls"
    )
    local root=""
    local picked=""

    for root in "${roots[@]}"; do
        [[ -d "$root" ]] || continue
        picked="$(find "$root" -type f \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' -o -iname '*.webp' \) | shuf -n 1)"
        if [[ -n "$picked" && -f "$picked" ]]; then
            printf '%s\n' "$picked"
            return 0
        fi
    done

    printf '%s\n' ""
}

render_hanauta_lock_image() {
    local src="$1"
    local out="$2"
    local clock_text=""
    local day_text=""
    local date_text=""
    local weather_text=""
    local screen_w=1920
    local screen_h=1080

    [[ -f "$src" ]] || return 1
    command -v magick >/dev/null 2>&1 || return 1

    clock_text="$(date '+%H:%M')"
    day_text="$(date '+%A')"
    date_text="$(date '+%d %B %Y')"
    weather_text="$(get_weather_overlay_text)"
    local monitor_size
    monitor_size="$(get_primary_monitor_size)"
    if [[ "$monitor_size" =~ ^([0-9]+)[[:space:]]+([0-9]+)$ ]]; then
        screen_w="${BASH_REMATCH[1]}"
        screen_h="${BASH_REMATCH[2]}"
    fi

    magick "$src" \
        -auto-orient \
        -resize "${screen_w}x${screen_h}^" \
        -gravity center \
        -extent "${screen_w}x${screen_h}" \
        \( -size "${overlay_width}x${overlay_height}" xc:none -fill "$theme_panel_fill" -draw "roundrectangle 0,0 $((overlay_width - 1)),$((overlay_height - 1)) 34,34" \) \
        -gravity south -geometry "+0+${overlay_bottom_margin}" -composite \
        -font "$theme_font" -fill "#${theme_time_color:0:6}" -pointsize 112 -gravity south -annotate +0+220 "$clock_text" \
        -font "$theme_font" -fill '#97ccf9' -pointsize 34 -gravity south -annotate +0+150 "$day_text" \
        -font "$theme_font" -fill "#${theme_greeter_color:0:6}" -pointsize 26 -gravity south -annotate +0+112 "$date_text" \
        -font "$theme_font" -fill "#${theme_weather_color:0:6}" -pointsize 20 -gravity south -annotate +0+88 "$weather_text" \
        -font "$theme_font" -fill "#${theme_layout_color:0:6}" -pointsize 18 -gravity south -annotate +0+72 "♪ hanauta" \
        "$out"
}

get_weather_overlay_text() {
    local weather_cache="${HOME}/.local/state/hanauta/service/weather.json"
    local text=""

    [[ -f "$weather_cache" ]] || {
        printf '%s\n' "Weather unavailable"
        return 0
    }
    command -v python3 >/dev/null 2>&1 || {
        printf '%s\n' "Weather unavailable"
        return 0
    }

    text="$(
        python3 - "$weather_cache" <<'PY'
import json
import os
import re
import sys
from pathlib import Path

path = Path(sys.argv[1])
try:
    payload = json.loads(path.read_text(encoding="utf-8"))
except Exception:
    print("Weather unavailable")
    raise SystemExit(0)

requested = payload.get("requested", {}) if isinstance(payload.get("requested"), dict) else {}
forecast_payload = payload.get("payload", {}) if isinstance(payload.get("payload"), dict) else {}
current = forecast_payload.get("current", {}) if isinstance(forecast_payload.get("current"), dict) else {}
lang = (os.environ.get("LC_ALL") or os.environ.get("LANG") or os.environ.get("LC_MESSAGES") or "en").lower()
is_pt = lang.startswith("pt")

temp = current.get("temperature_2m")
code = current.get("weather_code")
humidity = current.get("relative_humidity_2m")
wind = current.get("wind_speed_10m")
name = requested.get("name", "")

def fix_name(raw):
    if not raw:
        return ""
    text = str(raw)
    if "\\u" in text:
        try:
            return text.encode("utf-8").decode("unicode_escape")
        except Exception:
            return text
    if re.search(r"u00[0-9a-fA-F]{2}", text):
        try:
            return re.sub(
                r"u00([0-9a-fA-F]{2})",
                lambda m: bytes.fromhex(m.group(1)).decode("latin-1"),
                text,
            )
        except Exception:
            return text
    return text

name = fix_name(name)

code_map_en = {
    0: "Clear",
    1: "Mainly clear",
    2: "Partly cloudy",
    3: "Overcast",
    45: "Fog",
    48: "Rime fog",
    51: "Light drizzle",
    53: "Drizzle",
    55: "Dense drizzle",
    61: "Light rain",
    63: "Rain",
    65: "Heavy rain",
    71: "Light snow",
    73: "Snow",
    75: "Heavy snow",
    80: "Rain showers",
    81: "Showers",
    82: "Heavy showers",
    95: "Thunderstorm",
    96: "Thunder + hail",
    99: "Severe thunder + hail",
}
code_map_pt = {
    0: "Céu limpo",
    1: "Pred. limpo",
    2: "Parc. nublado",
    3: "Encoberto",
    45: "Neblina",
    48: "Nevoeiro",
    51: "Garoa fraca",
    53: "Garoa",
    55: "Garoa forte",
    61: "Chuva fraca",
    63: "Chuva",
    65: "Chuva forte",
    71: "Neve fraca",
    73: "Neve",
    75: "Neve forte",
    80: "Panc. de chuva",
    81: "Aguaceiros",
    82: "Panc. fortes",
    95: "Tempestade",
    96: "Temp. + granizo",
    99: "Temp. severa",
}
code_map = code_map_pt if is_pt else code_map_en
desc = code_map.get(code, "Tempo" if is_pt else "Weather")

if temp is None:
    line = desc
else:
    try:
        temp_txt = f"{float(temp):.0f}°C"
    except Exception:
        temp_txt = f"{temp}°C"
    line = f"{desc} · {temp_txt}"

if humidity is not None:
    try:
        line = f"{line} · {'UR' if is_pt else 'RH'} {int(round(float(humidity)))}%"
    except Exception:
        pass
if wind is not None:
    try:
        line = f"{line} · {('Vento' if is_pt else 'Wind')} {int(round(float(wind)))} km/h"
    except Exception:
        pass

if name:
    line = f"{line} · {name}"

print(line or ("Tempo indisponível" if is_pt else "Weather unavailable"))
PY
    )"

    printf '%s\n' "${text:-Weather unavailable}"
}

load_lock_settings
ensure_theme_creator_theme
load_active_theme

if [[ "$refresh_rate" =~ ^[0-9]+$ ]]; then
    refresh_rate=$(( refresh_rate < 0 ? 0 : (refresh_rate > 30 ? 30 : refresh_rate) ))
else
    refresh_rate=1
fi
if [[ "$ring_radius" =~ ^[0-9]+$ ]]; then
    ring_radius=$(( ring_radius < 8 ? 8 : (ring_radius > 80 ? 80 : ring_radius) ))
else
    ring_radius=28
fi
if [[ "$ring_width" =~ ^[0-9]+$ ]]; then
    ring_width=$(( ring_width < 1 ? 1 : (ring_width > 24 ? 24 : ring_width) ))
else
    ring_width=6
fi

if [[ "$use_slow_fade" == "1" ]]; then
    slowfade start
fi
if [[ "$pause_media_on_lock" == "1" ]] && command -v mpc >/dev/null 2>&1 && run_quick mpc status >/dev/null 2>&1; then
    run_quick mpc pause >/dev/null 2>&1 || true
fi

tmp_raw=""
tmp_lock=""
cleanup() {
    [[ -n "$tmp_raw" && -f "$tmp_raw" ]] && rm -f "$tmp_raw"
    [[ -n "$tmp_lock" && -f "$tmp_lock" ]] && rm -f "$tmp_lock"
    if [[ "$use_slow_fade" == "1" ]]; then
        slowfade end || true
    fi
}
trap cleanup EXIT

wallpaper="$(pick_random_anime_wallpaper)"
if [[ -z "$wallpaper" ]]; then
    wallpaper="$(resolve_current_wallpaper)"
fi

lock_image="$wallpaper"
blur_enabled="${LOCK_SCREENSHOT_BLUR:-$lock_blur}"
if [[ "$blur_enabled" == "1" ]] && command -v maim >/dev/null 2>&1 && command -v magick >/dev/null 2>&1; then
    tmp_raw="$(mktemp --suffix=.png)"
    tmp_lock="$(mktemp --suffix=.png)"
    if run_quick maim "$tmp_raw" >/dev/null 2>&1; then
        if run_quick magick "$tmp_raw" -blur 0x8 "$tmp_lock" >/dev/null 2>&1; then
            lock_image="$tmp_lock"
        fi
    fi
fi

# betterlockscreen/i3lock image path compatibility:
# if current wallpaper is not PNG, convert to a temporary PNG first.
if [[ -n "$lock_image" && -f "$lock_image" ]]; then
    case "${lock_image,,}" in
        *.png) ;;
        *)
            if command -v magick >/dev/null 2>&1; then
                tmp_lock="$(mktemp --suffix=.png)"
                if run_quick magick "$lock_image" "$tmp_lock" >/dev/null 2>&1; then
                    lock_image="$tmp_lock"
                fi
            fi
            ;;
    esac
fi
# Produce a themed lock image with clock/day overlay.
if [[ -n "$lock_image" && -f "$lock_image" ]] && command -v magick >/dev/null 2>&1; then
    tmp_raw="$(mktemp --suffix=.png)"
    if render_hanauta_lock_image "$lock_image" "$tmp_raw"; then
        lock_image="$tmp_raw"
    fi
fi

locker="$(command -v i3lock || true)"
if [[ -z "$locker" ]]; then
    echo "i3lock is required but not installed. Install it and rerun lock." >&2
    exit 1
fi

# Direct i3lock image path avoids betterlockscreen fallback artifacts/extra login box.
if [[ -n "$lock_image" && -f "$lock_image" ]]; then
    "$locker" -n -e -t -i "$lock_image" -p default
else
    "$locker" -n -e -c 000000 -p default
fi
