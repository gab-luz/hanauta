# i3 config generated from a prior bspwm setup on 2026-03-03

set $mod Mod4
font pango:DejaVu Sans Mono 10
floating_modifier $mod

# Workspaces
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

bindsym $mod+1 workspace $ws1
bindsym $mod+2 workspace $ws2
bindsym $mod+3 workspace $ws3
bindsym $mod+4 workspace $ws4
bindsym $mod+5 workspace $ws5
bindsym $mod+6 workspace $ws6
bindsym $mod+7 workspace $ws7
bindsym $mod+8 workspace $ws8
bindsym $mod+9 workspace $ws9
bindsym $mod+0 workspace $ws10
bindsym $mod+Shift+1 move container to workspace $ws1
bindsym $mod+Shift+2 move container to workspace $ws2
bindsym $mod+Shift+3 move container to workspace $ws3
bindsym $mod+Shift+4 move container to workspace $ws4
bindsym $mod+Shift+5 move container to workspace $ws5
bindsym $mod+Shift+6 move container to workspace $ws6
bindsym $mod+Shift+7 move container to workspace $ws7
bindsym $mod+Shift+8 move container to workspace $ws8
bindsym $mod+Shift+9 move container to workspace $ws9
bindsym $mod+Shift+0 move container to workspace $ws10

# Gaps/borders (requires i3-gaps)
# bspwm: border_width=0, window_gap=20, border_radius=15 (no i3 equivalent)
# If you are on vanilla i3, comment out the gaps lines.
set $gap 1
default_border pixel 3
default_floating_border pixel 3
for_window [window_type="normal"] border pixel 3
gaps inner $gap
gaps outer $gap
# this gap is the gap between window and things like hanauta bar or the hanauta dock
gaps top 5

# Colors
# format: client.<state> border background text indicator child_border
client.focused          #bece7f #bece7f #e4e3d7 #bece7f #bece7f
client.focused_inactive #919283 #919283 #e4e3d7 #919283 #919283
client.unfocused        #919283 #919283 #e4e3d7 #919283 #919283
client.urgent           #ffb4ab #ffb4ab #13140d #ffb4ab #ffb4ab
client.placeholder      #919283 #919283 #e4e3d7 #919283 #919283
client.background       #13140d

# Startup (from bspwmrc)
exec_always --no-startup-id xsetroot -cursor_name left_ptr

# Notifications are handled by Hanauta's native PyQt notification daemon from startup.sh

# Startup apps (run once per i3 start)
exec --no-startup-id sh -c 'sleep 10 && "$HOME/.config/i3/scripts/bspfloat" floating 5 > "$HOME/.log.bspfloat.txt" 2>&1'
# exec --no-startup-id sh -c "$HOME/.config/conky/Auva/start.sh"
exec --no-startup-id sh -c 'command -v lxqt-policykit-agent >/dev/null 2>&1 && lxqt-policykit-agent'
exec --no-startup-id sh -c 'command -v xfce4-power-manager >/dev/null 2>&1 && xfce4-power-manager'
exec --no-startup-id sh -c 'if command -v clipit >/dev/null 2>&1; then clipit; elif command -v copyq >/dev/null 2>&1; then copyq; fi'
exec_always --no-startup-id sh -c 'pkill -x fastcompmgr 2>/dev/null; pkill -x picom 2>/dev/null; picom --config "$HOME/.config/i3/picom.conf" --daemon'
exec_always --no-startup-id ~/.config/i3/startup.sh

# CyberDock
exec_always --no-startup-id sh -c 'pkill -x hanauta-dock 2>/dev/null || true; pkill -f "$HOME/.config/i3/hanauta/src/pyqt/dock/dock.py" 2>/dev/null || true; export PYTHONPATH="$HOME/.config/i3/hanauta/src${PYTHONPATH:+:$PYTHONPATH}"; if [ -x "$HOME/.config/i3/.venv/bin/python" ]; then exec "$HOME/.config/i3/.venv/bin/python" "$HOME/.config/i3/hanauta/src/pyqt/dock/dock.py"; else exec python3 "$HOME/.config/i3/hanauta/src/pyqt/dock/dock.py"; fi'

# CyberBar (PyQt6 top bar)
exec_always --no-startup-id sh -c 'pkill -x hanauta-bar 2>/dev/null || true; pkill -x hanauta-game-mode-popup 2>/dev/null || true; pkill -x hanauta-ai-popup 2>/dev/null || true; pkill -f "$HOME/.config/i3/hanauta/src/pyqt/bar/ui_bar.py" 2>/dev/null || true; pkill -f "$HOME/.config/i3/hanauta/src/pyqt/ai-popup/ai_popup.py" 2>/dev/null || true; export PYTHONPATH="$HOME/.config/i3/hanauta/src${PYTHONPATH:+:$PYTHONPATH}"; if [ -x "$HOME/.config/i3/.venv/bin/python" ]; then exec "$HOME/.config/i3/.venv/bin/python" "$HOME/.config/i3/hanauta/src/pyqt/bar/ui_bar.py" --ui "$HOME/.config/i3/hanauta/src/pyqt/bar/bar.ui"; else exec python3 "$HOME/.config/i3/hanauta/src/pyqt/bar/ui_bar.py" --ui "$HOME/.config/i3/hanauta/src/pyqt/bar/bar.ui"; fi'

# Window rules (translated from bspwm rules)
for_window [class=Peek] floating enable
# for_window [class=kitty] floating enable
for_window [class=conky-manager2] floating enable
for_window [class=Kupfer.py] focus
for_window [class=Screenkey] floating enable, border pixel 0

for_window [class="mpv"] floating enable, resize set 1090 615, move position center
for_window [class=Rofi] floating enable
# for_window [class=Ferdium] floating enable, move position center
for_window [class="com-abdownloadmanager-desktop-AppKt"] floating enable, move position center
for_window [class="copyq"] floating enable, resize set 550 410, move position center
for_window [class="Audacious"] floating enable, resize set 550 410, move position center
for_window [class=GLava] floating enable, sticky enable, border pixel 0
for_window [class=GLava] move position 0 0
for_window [class=GLava] resize set 1920 1080

# CyberDock window rules
for_window [class="CyberDock"] floating enable, border pixel 0, sticky enable

# CyberBar window rules
for_window [class="CyberBar"] floating enable, border pixel 0, sticky enable
for_window [title="CyberBar"] floating enable, border pixel 0, sticky enable
for_window [class="CyberBar"] move position 0 0
for_window [title="CyberBar"] move position 0 0
for_window [class="CyberBar"] resize set 1920 40
for_window [title="CyberBar"] resize set 1920 40
for_window [class="CyberBar"] exec --no-startup-id xdotool getactivewindow set_window_strut top 40 0 0 0

# Hotkeys overlay window rules
for_window [class="HanautaHotkeys"] floating enable, border pixel 0, sticky enable
for_window [title="Hanauta Hotkeys"] floating enable, border pixel 0, sticky enable

# Desktop clock rules
for_window [class="HanautaDesktopClock"] floating enable, border pixel 0
for_window [title="Hanauta Desktop Clock"] floating enable, border pixel 0
no_focus [title="Hanauta Desktop Clock"]

# Window switcher rules
for_window [title="Hanauta Window Switcher"] floating enable, border pixel 0, sticky enable

# Hanauta AI popup should open as floating immediately
for_window [title="Hanauta AI"] floating enable, border pixel 0

# Power menu overlay rules
for_window [title="Power Menu"] floating enable, border pixel 0, sticky enable

# Hanauta notification toasts should never take focus
for_window [class="HanautaNotification"] floating enable, border pixel 0, sticky enable
for_window [title="^Hanauta Notification .*"] floating enable, border pixel 0, sticky enable
no_focus [title="^Hanauta Notification .*"]
no_focus [class="HanautaNotification"]

# Hanauta fullscreen reminders should stay visible across workspaces
for_window [class="HanautaReminder"] floating enable, border pixel 0, sticky enable
for_window [title="Hanauta Reminder"] floating enable, border pixel 0, sticky enable

# Basic i3 controls
bindsym $mod+Return exec --no-startup-id kitty
bindsym --release Print exec --no-startup-id flameshot gui
bindsym Mod1+Tab exec --no-startup-id "$HOME/.config/i3/scripts/alt_tab.sh"
bindsym Mod1+F1 exec --no-startup-id "$HOME/.config/i3/hanauta/bin/hanauta-hotkeys-overlay"
bindsym $mod+space exec --no-startup-id "$HOME/.config/i3/hanauta/scripts/open_launcher.sh"
bindsym $mod+w exec --no-startup-id "$HOME/.config/i3/hanauta/scripts/open_wallpaper_manager.sh"
bindsym $mod+q kill
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l exec --no-startup-id "$HOME/.config/i3/hanauta/scripts/lock"
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right
bindsym $mod+Ctrl+l exec --no-startup-id "$HOME/.config/i3/hanauta/scripts/lock"
bindsym $mod+v split v
bindsym $mod+b split h
bindsym $mod+f fullscreen toggle
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
