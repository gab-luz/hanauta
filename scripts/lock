#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
ROOT_DIR="$(CDPATH= cd -- "${SCRIPT_DIR}/.." && pwd)"
TARGET_LOCK="${ROOT_DIR}/hanauta/scripts/lock"

if [[ -x "$TARGET_LOCK" ]]; then
    exec "$TARGET_LOCK" "$@"
fi

echo "Lock script not found or not executable: $TARGET_LOCK" >&2
exit 1
